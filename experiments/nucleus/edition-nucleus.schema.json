{
  "name": "EditionNucleus",
  "description": "Núcleo canónico de una edición Triggui. Ver prompt del sistema para la política editorial completa.",
  "strict": true,
  "schema": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "book_identity",
      "book_grounding_anchors",
      "lens_analysis",
      "card_es",
      "card_en",
      "emotional_words_es",
      "emotional_words_en",
      "og_phrases_es",
      "og_phrases_en",
      "edition_blocks_es",
      "edition_blocks_en",
      "visual_signature",
      "surface_hints",
      "lens_relevance",
      "confidence"
    ],
    "properties": {
      "book_identity": {
        "type": "object",
        "additionalProperties": false,
        "required": ["titulo_es", "titulo_en", "autor", "idioma_original"],
        "properties": {
          "titulo_es": { "type": "string", "description": "Título del libro en español. Si fue publicado en español, usa ese título exacto. Si fue publicado en inglés, usa la traducción oficial al español si existe." },
          "titulo_en": { "type": "string", "description": "Título ORIGINAL del libro en inglés si así fue publicado (ej. 'Peak Mind' para el libro de Amishi Jha, 'Atomic Habits' para el de James Clear). Si el libro fue publicado originalmente en español, usa una traducción funcional al inglés." },
          "autor": { "type": "string", "description": "Nombre COMPLETO del autor (ej. 'Amishi P. Jha', no 'Amishi'; 'James Clear', no 'J. Clear')." },
          "idioma_original": { "type": "string", "enum": ["es", "en"], "description": "Idioma en el que el libro fue escrito originalmente." }
        }
      },

      "book_grounding_anchors": {
        "type": "object",
        "additionalProperties": false,
        "required": ["book_known", "concepts", "key_terms", "authorial_voice_notes"],
        "properties": {
          "book_known": { "type": "boolean" },
          "concepts": {
            "type": "array",
            "minItems": 3,
            "maxItems": 5,
            "items": { "type": "string", "minLength": 10, "maxLength": 120 }
          },
          "key_terms": {
            "type": "array",
            "minItems": 3,
            "maxItems": 6,
            "items": { "type": "string", "minLength": 2, "maxLength": 40 }
          },
          "authorial_voice_notes": { "type": "string", "minLength": 50, "maxLength": 400 }
        }
      },

      "lens_analysis": {
        "type": "object",
        "additionalProperties": false,
        "required": ["lens_provided", "analysis", "decision"],
        "properties": {
          "lens_provided": { "type": "boolean" },
          "analysis": { "type": "string", "minLength": 10, "maxLength": 600 },
          "decision": {
            "type": "string",
            "enum": ["apply_directly", "apply_through_adjacent_concept", "dont_apply_book_is_about_something_else"]
          }
        }
      },

      "card_es": {
        "type": "object",
        "additionalProperties": false,
        "required": ["titulo", "parrafoTop", "subtitulo", "parrafoBot"],
        "properties": {
          "titulo": { "type": "string", "minLength": 8, "maxLength": 60 },
          "parrafoTop": { "type": "string", "minLength": 80, "maxLength": 320 },
          "subtitulo": { "type": "string", "minLength": 20, "maxLength": 120 },
          "parrafoBot": { "type": "string", "minLength": 80, "maxLength": 320 }
        }
      },

      "card_en": {
        "type": "object",
        "additionalProperties": false,
        "required": ["titulo", "parrafoTop", "subtitulo", "parrafoBot"],
        "properties": {
          "titulo": { "type": "string", "minLength": 8, "maxLength": 60 },
          "parrafoTop": { "type": "string", "minLength": 80, "maxLength": 320 },
          "subtitulo": { "type": "string", "minLength": 20, "maxLength": 120 },
          "parrafoBot": { "type": "string", "minLength": 80, "maxLength": 320 }
        }
      },

      "emotional_words_es": {
        "type": "array",
        "minItems": 4,
        "maxItems": 4,
        "items": { "type": "string", "minLength": 3, "maxLength": 25 }
      },

      "emotional_words_en": {
        "type": "array",
        "minItems": 4,
        "maxItems": 4,
        "items": { "type": "string", "minLength": 3, "maxLength": 25 }
      },

      "og_phrases_es": {
        "type": "array",
        "minItems": 4,
        "maxItems": 4,
        "items": { "type": "string", "minLength": 35, "maxLength": 74 }
      },

      "og_phrases_en": {
        "type": "array",
        "minItems": 4,
        "maxItems": 4,
        "items": { "type": "string", "minLength": 35, "maxLength": 74 }
      },

      "edition_blocks_es": {
        "type": "array",
        "minItems": 4,
        "maxItems": 4,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["gesture_type", "phrase"],
          "properties": {
            "gesture_type": {
              "type": "string",
              "enum": ["instruccion_sensorial", "pregunta_directa", "imagen_concreta", "aforismo_autorial"]
            },
            "phrase": { "type": "string", "minLength": 50, "maxLength": 110 }
          }
        }
      },

      "edition_blocks_en": {
        "type": "array",
        "minItems": 4,
        "maxItems": 4,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["gesture_type", "phrase"],
          "properties": {
            "gesture_type": {
              "type": "string",
              "enum": ["sensory_instruction", "direct_question", "concrete_image", "authorial_aphorism"]
            },
            "phrase": { "type": "string", "minLength": 50, "maxLength": 110 }
          }
        }
      },

      "visual_signature": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "palette",
          "accent",
          "paper",
          "ink",
          "typography_family",
          "density",
          "temperature",
          "rhythm",
          "era",
          "genre_visual"
        ],
        "properties": {
          "palette": { "type": "array", "minItems": 4, "maxItems": 4, "items": { "type": "string" } },
          "accent": { "type": "string" },
          "paper": { "type": "string" },
          "ink": { "type": "string" },
          "typography_family": {
            "type": "string",
            "enum": ["serif_clasico", "serif_literario", "serif_moderno", "sans_geometrico", "sans_humanista", "sans_tecnologico", "mono_precision", "mixta_editorial"]
          },
          "density": { "type": "string", "enum": ["aireado", "equilibrado", "denso"] },
          "temperature": { "type": "string", "enum": ["frio", "neutro", "calido", "ardiente"] },
          "rhythm": { "type": "string", "enum": ["lento", "medio", "rapido", "staccato"] },
          "era": { "type": "string", "enum": ["clasico", "moderno", "contemporaneo", "atemporal"] },
          "genre_visual": { "type": "string", "enum": ["academico", "literario", "manifiesto", "poesia", "narrativa", "ensayo", "tecnico", "espiritual"] }
        }
      },

      "surface_hints": {
        "type": "object",
        "additionalProperties": false,
        "required": ["dimension", "punto_hawkins", "franja_ideal"],
        "properties": {
          "dimension": { "type": "string", "enum": ["Bienestar", "Prosperidad", "Conexion"] },
          "punto_hawkins": { "type": "string", "enum": ["Cero", "Creativo", "Activo", "Maximo"] },
          "franja_ideal": { "type": "string", "enum": ["madrugada", "manana", "tarde", "noche"] }
        }
      },

      "lens_relevance": {
        "type": "object",
        "additionalProperties": false,
        "required": ["applied", "reason"],
        "properties": {
          "applied": { "type": "boolean" },
          "reason": { "type": "string", "maxLength": 200 }
        }
      },

      "confidence": {
        "type": "object",
        "additionalProperties": false,
        "required": ["book_grounding", "voice_authenticity", "specificity"],
        "properties": {
          "book_grounding": { "type": "number" },
          "voice_authenticity": { "type": "number" },
          "specificity": { "type": "number" }
        }
      }
    }
  }
}
