{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Triggui Editorial Nucleus",
  "description": "Esquema canónico del núcleo semántico editorial de Triggui. Es la única fuente de verdad previa a cualquier superficie de salida: tarjeta, bloques, email, edición viva u OG.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "trigger",
    "lens",
    "book_selection",
    "theme",
    "editorial_voice",
    "output_constraints",
    "surface_candidates"
  ],
  "properties": {
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw",
        "source",
        "moment_type",
        "time_context"
      ],
      "properties": {
        "raw": {
          "type": "string",
          "description": "Detonante original en lenguaje natural. Puede venir de una observación de Badir, del sistema o de una nota manual.",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "enum": ["badir", "manual", "system"],
          "description": "Origen del detonante."
        },
        "moment_type": {
          "type": "string",
          "enum": [
            "body",
            "mind",
            "relationships",
            "work",
            "spirit",
            "money",
            "family",
            "other"
          ],
          "description": "Dominio humano principal del momento."
        },
        "time_context": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "weekday",
            "hour",
            "energy",
            "chronobiology_mode"
          ],
          "properties": {
            "weekday": {
              "type": "string",
              "enum": [
                "lunes",
                "martes",
                "miércoles",
                "jueves",
                "viernes",
                "sábado",
                "domingo"
              ]
            },
            "hour": {
              "type": "integer",
              "minimum": 0,
              "maximum": 23
            },
            "energy": {
              "type": "number",
              "minimum": 0,
              "maximum": 2,
              "description": "Escala flexible de energía percibida. 1.0 es neutro."
            },
            "chronobiology_mode": {
              "type": "string",
              "enum": [
                "madrugada",
                "manana",
                "mediodia",
                "tarde",
                "noche"
              ]
            }
          }
        }
      }
    },
    "lens": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary",
        "secondary",
        "bias_strength"
      ],
      "properties": {
        "primary": {
          "type": "string",
          "description": "Lente principal activo. Ej.: self-knowledge, game-theory, chronobiology."
        },
        "secondary": {
          "type": "array",
          "description": "Lentes secundarios opcionales que matizan el razonamiento sin romper la congruencia.",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "bias_strength": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Fuerza del sesgo del lente sobre la lectura editorial. 0 = mínimo, 1 = dominante."
        }
      }
    },
    "book_selection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "author",
        "why_this_book",
        "confidence",
        "alternatives"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "author": {
          "type": "string",
          "minLength": 1
        },
        "why_this_book": {
          "type": "string",
          "description": "Razón concreta de selección. Debe conectar detonante, lente y singularidad del libro."
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "alternatives": {
          "type": "array",
          "description": "Libros alternativos posibles para el mismo detonante.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["title", "author", "reason"],
            "properties": {
              "title": { "type": "string" },
              "author": { "type": "string" },
              "reason": { "type": "string" }
            }
          },
          "default": []
        }
      }
    },
    "theme": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "core",
        "subtheme",
        "human_tension",
        "useful_truth",
        "practical_shift"
      ],
      "properties": {
        "core": {
          "type": "string",
          "description": "Tema principal del núcleo editorial."
        },
        "subtheme": {
          "type": "string",
          "description": "Matiz o derivación concreta del tema principal."
        },
        "human_tension": {
          "type": "string",
          "description": "Tensión humana central que hace que el tema importe aquí y ahora."
        },
        "useful_truth": {
          "type": "string",
          "description": "Verdad útil, específica, no genérica, que la pieza debe dejar en el lector."
        },
        "practical_shift": {
          "type": "string",
          "description": "Pequeño giro práctico que el lector puede aplicar de inmediato."
        }
      }
    },
    "editorial_voice": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stance",
        "intensity",
        "first_person"
      ],
      "properties": {
        "stance": {
          "type": "string",
          "enum": [
            "observational",
            "intimate",
            "aphoristic",
            "surgical",
            "contemplative",
            "direct"
          ],
          "description": "Distancia narrativa elegida para esta pieza."
        },
        "intensity": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "Nivel de confrontación o contundencia."
        },
        "first_person": {
          "type": "boolean",
          "description": "Por defecto debe ir en false para el núcleo canónico."
        }
      }
    },
    "output_constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "must_be_specific_to_book",
        "must_be_actionable",
        "must_avoid_genericity",
        "must_preserve_ethics"
      ],
      "properties": {
        "must_be_specific_to_book": {
          "type": "boolean",
          "const": true
        },
        "must_be_actionable": {
          "type": "boolean",
          "const": true
        },
        "must_avoid_genericity": {
          "type": "boolean",
          "const": true
        },
        "must_preserve_ethics": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "surface_candidates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "highlights",
        "title_concepts",
        "subtitle_bridges",
        "action_15_60_sec"
      ],
      "properties": {
        "highlights": {
          "type": "array",
          "description": "Frases potenciales para [H]...[/H]. Nunca palabras sueltas.",
          "items": {
            "type": "string"
          },
          "minItems": 0,
          "default": []
        },
        "title_concepts": {
          "type": "array",
          "description": "Conceptos de título, no títulos cerrados necesariamente.",
          "items": {
            "type": "string"
          },
          "minItems": 0,
          "default": []
        },
        "subtitle_bridges": {
          "type": "array",
          "description": "Puentes emocionales o bisagras conceptuales entre párrafo 1 y párrafo 2.",
          "items": {
            "type": "string"
          },
          "minItems": 0,
          "default": []
        },
        "action_15_60_sec": {
          "type": "array",
          "description": "Microacciones concretas derivables para el lector.",
          "items": {
            "type": "string"
          },
          "minItems": 0,
          "default": []
        }
      }
    }
  }
}